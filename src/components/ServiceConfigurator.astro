    box-shadow: 0 4px 14px rgba(99, 91, 255, 0.2);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .stripe-pay-btn:hover {
    background: #7a73ff;
    box-shadow: 0 6px 20px rgba(99, 91, 255, 0.35);
    transform: translateY(-1px);
  }

  /* Standard CTA Detail fallback */
  .cta-detail {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }
  .cta-detail h2 {
    font-size: 1.8rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
  }
  .cta-detail p {
