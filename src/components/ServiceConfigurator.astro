    margin-bottom: 1.5rem;
  }

  /* Stripe Loading / Success Modal Overlay */
  .stripe-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(8px);
    z-index: 99998;
    transition: opacity 0.3s ease;
  }

  .stripe-modal {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(calc(100vw - 2rem), 480px);
    background: #1C1C1E;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.8);
    z-index: 99999;
    overflow: hidden;
  }

  .stripe-modal-content {
    padding: 2.5rem;
    text-align: center;
  }

  .stripe-loading-screen, .stripe-success-screen {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .stripe-spinner {
    width: 48px;
    height: 48px;
    border: 3px solid rgba(99, 91, 255, 0.15);
    border-top: 3px solid #635bff;
    border-radius: 50%;
    animation: stripe-spin 1s linear infinite;
  }

  @keyframes stripe-spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .stripe-loading-screen h4, .stripe-success-screen h4 {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin-top: 0.5rem;
  }

  .stripe-loading-screen p, .stripe-success-screen p {
    font-size: 13.5px;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .success-icon-wrapper {
    width: 64px;
    height: 64px;
    background: rgba(48, 209, 88, 0.1);
    border: 1px solid rgba(48, 209, 88, 0.25);
    color: #30d158;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .success-checkmark {
    animation: scale-in 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes scale-in {
    0% { transform: scale(0.6); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  .redirect-msg {
    font-size: 12px !important;
    color: var(--color-text-muted) !important;
    background: rgba(255, 255, 255, 0.02);
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    margin: 0.5rem 0;
  }

  .stripe-success-screen button {
    width: 100%;
    margin-top: 0.5rem;
  }
</style>

<script>
  // Script handles dynamic price calculations and Stripe checkout simulation.
  document.addEventListener('DOMContentLoaded', () => {
    setupWebDev();
    setupHourly();
    setupHardware();
    setupBooking();
    setupModal();
  });

  // Modal setup
  function setupModal() {
    const modal = document.getElementById('stripe-modal');
    const overlay = document.getElementById('stripe-overlay');
    const loadingScreen = document.getElementById('stripe-loading');
    const successScreen = document.getElementById('stripe-success');
    const closeBtn = document.getElementById('close-stripe-success');
    const payBtns = document.querySelectorAll('.stripe-pay-btn');

    if (!modal || !overlay) return;

    function showModal() {
      modal.removeAttribute('hidden');
      overlay.removeAttribute('hidden');
      loadingScreen.style.display = 'flex';
      successScreen.style.display = 'none';
      document.body.style.overflow = 'hidden';

      // Simulate Stripe loading redirect and completion
      setTimeout(() => {
        loadingScreen.style.display = 'none';
        successScreen.style.display = 'flex';
      }, 2500);
    }

    function closeModal() {
      modal.setAttribute('hidden', '');
      overlay.setAttribute('hidden', '');
      document.body.style.overflow = '';
    }

    payBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        showModal();
      });
    });

    closeBtn?.addEventListener('click', closeModal);
    overlay.addEventListener('click', closeModal);
  }

  // 1. Web Dev Configurator
  function setupWebDev() {
    const seoCheck = document.getElementById('webdev-seo') as HTMLInputElement;
    const hostingCheck = document.getElementById('webdev-hosting') as HTMLInputElement;
    const domainCheck = document.getElementById('webdev-domain') as HTMLInputElement;
    const totalEl = document.getElementById('webdev-total');
    
    const rowSeo = document.getElementById('row-seo');
    const rowHosting = document.getElementById('row-hosting');
    const rowDomain = document.getElementById('row-domain');

    const fileInput = document.getElementById('webdev-files') as HTMLInputElement;
    const fileList = document.getElementById('file-list');

    if (fileInput && fileList) {
      fileInput.addEventListener('change', () => {
        const files = Array.from(fileInput.files || []);
        if (files.length === 0) {
          fileList.textContent = 'Nessun file selezionato';
        } else {
          fileList.textContent = files.map(f => f.name).join(', ');
        }
      });
    }

    if (!totalEl) return;

    function updatePrice() {
      let total = 1200;
      if (seoCheck?.checked) {
        total += 600;
        if (rowSeo) rowSeo.style.display = 'flex';
      } else {
        if (rowSeo) rowSeo.style.display = 'none';
      }

      if (hostingCheck?.checked) {
        total += 240;
        if (rowHosting) rowHosting.style.display = 'flex';
      } else {
        if (rowHosting) rowHosting.style.display = 'none';
      }

      if (domainCheck?.checked) {
        total += 20;
        if (rowDomain) rowDomain.style.display = 'flex';
      } else {
        if (rowDomain) rowDomain.style.display = 'none';
      }

      totalEl.textContent = `€${total.toLocaleString('it-IT')}`;
    }

    seoCheck?.addEventListener('change', updatePrice);
    hostingCheck?.addEventListener('change', updatePrice);
    domainCheck?.addEventListener('change', updatePrice);
    updatePrice();
  }

  // 2. Hourly Configurator
  function setupHourly() {
    const cards = document.querySelectorAll('.config-flow[data-type="hourly"] .pack-card');
    const totalEl = document.getElementById('hourly-total');

    if (!totalEl) return;

    cards.forEach(card => {
      const input = card.querySelector('input[type="radio"]') as HTMLInputElement;
      card.addEventListener('click', () => {
        cards.forEach(c => c.classList.remove('active'));
        card.classList.add('active');
        if (input) {
          input.checked = true;
          let price = '€500/mese';
          if (input.value === 'advanced') price = '€900/mese';
          if (input.value === 'enterprise') price = '€2.000/mese';
          totalEl.textContent = price;
        }
      });
    });
  }

  // 3. Hardware Configurator
  function setupHardware() {
    const baseRows = document.querySelectorAll('.config-flow[data-type="hardware"] .hw-base-row');
    const upgradeCheck = document.getElementById('hw-upgrade') as HTMLInputElement;
    const hardeningCheck = document.getElementById('hw-hardening') as HTMLInputElement;
    
    const baseTitleEl = document.getElementById('hw-base-title');
    const baseCostEl = document.getElementById('hw-base-cost');
    const rowUpgrade = document.getElementById('row-hw-upgrade');
    const rowHardening = document.getElementById('row-hw-hardening');
    const totalEl = document.getElementById('hardware-total');

    if (!totalEl) return;

    let baseCost = 2500;
    let baseTitle = 'Workstation Dev AI Base';

    function updatePrice() {
      let total = baseCost;

      if (baseTitleEl) baseTitleEl.textContent = baseTitle;
      if (baseCostEl) baseCostEl.textContent = `€${baseCost.toLocaleString('it-IT')}`;

      if (upgradeCheck?.checked) {
        total += 400;
        if (rowUpgrade) rowUpgrade.style.display = 'flex';
      } else {
        if (rowUpgrade) rowUpgrade.style.display = 'none';
      }

      if (hardeningCheck?.checked) {
        total += 300;
        if (rowHardening) rowHardening.style.display = 'flex';
      } else {
        if (rowHardening) rowHardening.style.display = 'none';
      }

      totalEl.textContent = `€${total.toLocaleString('it-IT')}`;
    }

    baseRows.forEach(row => {
      const input = row.querySelector('input[type="radio"]') as HTMLInputElement;
      row.addEventListener('click', () => {
        baseRows.forEach(r => r.classList.remove('active'));
        row.classList.add('active');
        if (input) {
          input.checked = true;
          if (input.value === 'workstation') {
            baseCost = 2500;
            baseTitle = 'Workstation Dev AI Base';
          } else if (input.value === 'server-pro') {
            baseCost = 5800;
            baseTitle = 'Server AI Locale Pro Base';
          } else if (input.value === 'server-enterprise') {
            baseCost = 12500;
            baseTitle = 'Server AI Enterprise Base';
          }
          updatePrice();
        }
      });
    });

    upgradeCheck?.addEventListener('change', updatePrice);
    hardeningCheck?.addEventListener('change', updatePrice);
    updatePrice();
  }

  // 4. Booking Configurator Tab System
  function setupBooking() {
    const tabs = document.querySelectorAll('.booking-tab-btn');
    const tabContents = document.querySelectorAll('.booking-tab-content');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const tabName = tab.getAttribute('data-tab');
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        tabContents.forEach(content => {
          content.classList.remove('active');
          if (content.id === `tab-content-${tabName}`) {
            content.classList.add('active');
          }
        });
      });
    });
  }
</script>
