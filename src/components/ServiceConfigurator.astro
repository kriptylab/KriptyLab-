---
// src/components/ServiceConfigurator.astro
interface Props {
  slug: string;
}

const { slug } = Astro.props;

// Determine which configurator type to show
const isWebDev = slug === 'sviluppo-siti-web';
const isHourlyPack = slug === 'assistenza-tecnica' || slug === 'cybersecurity';
const isHardware = slug === 'assemblaggio-hardware';
const isBooking = slug === 'sistemi-appuntamento';

const hasConfigurator = isWebDev || isHourlyPack || isHardware || isBooking;
---

{hasConfigurator ? (
  <div class="configurator-wrapper card reveal-up" id="configurator-section">
    <div class="configurator-inner">
      <div class="configurator-header">
        <div class="stripe-badge">
          <svg class="stripe-icon" width="40" height="16" viewBox="0 0 40 16" fill="currentColor">
            <path d="M40 7.82c0-.58-.08-1.12-.24-1.61a3.86 3.86 0 0 0-1.89-2.31A6.74 6.74 0 0 0 35 3.14a6.41 6.41 0 0 0-4.08 1.25 5.56 5.56 0 0 0-1.87 3.43c0 .58.07 1.13.23 1.62a3.86 3.86 0 0 0 1.9 2.31c.71.37 1.48.56 2.33.56a6.6 6.6 0 0 0 4.14-1.28A5.4 5.4 0 0 0 40 7.82zm-2.58.03c0 .9-.6 1.42-1.57 1.42a1.8 1.8 0 0 1-1.39-.56c-.28-.3-.42-.78-.42-1.42 0-.89.58-1.42 1.55-1.42a1.8 1.8 0 0 1 1.41.56c.28.3.42.79.42 1.42zm-9.3-4.47a5.53 5.53 0 0 0-3.3 1v-.78h-2.36v9.13l2.56-.54V9.82a5.53 5.53 0 0 0 3.3 1c2.14 0 3.65-1.43 3.65-3.83s-1.5-3.83-3.65-3.83zm-.54 5.92c-.93 0-1.4-.42-1.4-1.29v-1.1c0-.85.47-1.27 1.4-1.27.87 0 1.34.42 1.34 1.27v1.1c0 .87-.47 1.29-1.34 1.29zm-7.65-5.92c-.99 0-1.74.34-2.28 1v-.78h-2.37V12.1l2.56-.54V8.42c0-1.36.7-1.95 1.76-1.95.27 0 .52.05.74.14v-2.3a3.42 3.42 0 0 0-.41-.03zm-7.98-.3c-1.16 0-1.85.52-2.14 1V3.38h-2.56V12.1l2.56-.54V7.54c0-.98.66-1.39 1.44-1.39.22 0 .44.03.65.1V3.97a3.02 3.02 0 0 0-.66-.1zm-5.46-.22a3.83 3.83 0 0 0-2.8-1c-2.32 0-3.8 1.45-3.8 3.83 0 2.37 1.5 3.83 3.82 3.83 1.15 0 2.1-.34 2.78-1l-1.07-1.34a3.17 3.17 0 0 1-1.71.51c-1 0-1.57-.48-1.57-1.42h4.52V7.12c0-2.37-1.47-3.83-3.8-3.83zm-1.32 2.5c0-.89.56-1.32 1.32-1.32.74 0 1.28.43 1.28 1.32h-2.6zM2.56 5.56H0V3.38h2.56v2.18z"/>
          </svg>
          <span class="secure-label">Pagamento Sicuro Integrato</span>
        </div>
        <h3 class="configurator-title">Configura il tuo Servizio</h3>
        <p class="configurator-subtitle">Personalizza le opzioni e calcola il preventivo in tempo reale prima del pagamento.</p>
      </div>

      <!-- 1. WEB DEV CONFIGURATOR -->
      {isWebDev && (
        <div class="config-flow" data-type="webdev">
          <div class="config-group">
            <span class="group-label">Opzioni Aggiuntive</span>
            
            <label class="option-row">
              <input type="checkbox" id="webdev-seo" class="config-checkbox" checked />
              <span class="checkbox-custom"></span>
              <span class="option-details">
                <span class="option-name">Indicizzazione Avanzata & SEO / GEO / AEO <span class="badge badge-mini">Consigliato</span></span>
                <span class="option-desc">Studio approfondito delle parole chiave locali e ottimizzazione semantica per posizionarsi sui motori di ricerca e AI (ChatGPT, Perplexity, Gemini).</span>
              </span>
              <span class="option-price">+€600</span>
            </label>

            <label class="option-row">
              <input type="checkbox" id="webdev-hosting" class="config-checkbox" />
              <span class="checkbox-custom"></span>
              <span class="option-details">
                <span class="option-name">Hosting Professionale Managed (Annuale)</span>
                <span class="option-desc">Spazio web ultra-veloce e isolato ospitato sulle nostre VPS proprietarie dedicate. Prestazioni ottimizzate, monitoraggio proattivo 24/7, certificato SSL e manutenzione ordinaria inclusa.</span>
              </span>
              <span class="option-price">+€240/anno</span>
            </label>

            <label class="option-row">
              <input type="checkbox" id="webdev-domain" class="config-checkbox" />
              <span class="checkbox-custom"></span>
              <span class="option-details">
                <span class="option-name">Registrazione e Gestione Dominio (Annuale)</span>
                <span class="option-desc">Registrazione del dominio (.it, .com, .net, ecc.) a nome del cliente, gestione dei DNS tramite Cloudflare per massime prestazioni e protezione.</span>
              </span>
              <span class="option-price">+€20/anno</span>
            </label>
          </div>

          <div class="config-group">
            <span class="group-label">Dettagli del Progetto</span>
            
            <div class="input-field">
              <label for="webdev-domain-pref" class="form-label">Preferenza Nome Dominio</label>
              <input type="text" id="webdev-domain-pref" class="form-input" placeholder="es. miazienda.it o studiolegale.com" />
            </div>

            <div class="input-field">
              <label for="webdev-project-info" class="form-label">Contenuti e Informazioni per il Sito</label>
              <textarea id="webdev-project-info" class="form-input" rows="3" placeholder="Fornisci dettagli o preferenze per il sito (es. numero pagine, sezioni richieste, ecc.)"></textarea>
            </div>

            <div class="input-field">
              <label class="form-label">Carica Loghi o Materiale Informativo</label>
              <div class="file-upload-wrapper">
                <input type="file" id="webdev-files" class="file-upload-input" multiple />
                <div class="file-upload-btn">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                  <span>Seleziona file da caricare...</span>
                </div>
                <div id="file-list" class="file-list">Nessun file selezionato</div>
              </div>
            </div>
          </div>

          <div class="price-summary">
            <div class="summary-row">
              <span>Sviluppo Sito Web (Base)</span>
              <span>€1.200</span>
            </div>
            <div class="summary-row dynamic-row" id="row-seo">
              <span>SEO/GEO/AEO Ottimizzazione</span>
              <span>€600</span>
            </div>
            <div class="summary-row dynamic-row" id="row-hosting" style="display: none;">
              <span>Hosting Managed (1 Anno)</span>
              <span>€240</span>
            </div>
            <div class="summary-row dynamic-row" id="row-domain" style="display: none;">
              <span>Registrazione Dominio (1 Anno)</span>
              <span>€20</span>
            </div>
            <div class="summary-divider"></div>
            <div class="total-row">
              <span>Totale preventivato</span>
              <span class="total-amount" id="webdev-total">€1.800</span>
            </div>
          </div>

          <button class="btn btn-primary btn-lg stripe-pay-btn" id="pay-webdev">
            <span>Paga con Stripe</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </div>
      )}

      <!-- 2. HOURLY PACK CONFIGURATOR (Assistenza IT / Cybersecurity) -->
      {isHourlyPack && (
        <div class="config-flow" data-type="hourly">
          <div class="config-group">
            <span class="group-label">Seleziona il Pacchetto Mensile</span>
            
            <div class="packages-grid">
              <label class="pack-card active">
                <input type="radio" name="hourly-pack" value="basic" checked />
                <div class="pack-card-inner">
                  <div class="pack-header">
                    <span class="pack-name">Pack Basic</span>
                    <span class="pack-hours">10 Ore / mese</span>
                  </div>
                  <p class="pack-desc">Ideale per piccole imprese che necessitano di supporto sistemistico standard e monitoraggio base.</p>
                  <div class="pack-price">€500<span class="price-period">/mese</span></div>
                </div>
              </label>

              <label class="pack-card">
                <input type="radio" name="hourly-pack" value="advanced" />
                <div class="pack-card-inner">
                  <div class="pack-header">
                    <span class="pack-name">Pack Advanced <span class="badge badge-mini">Popolare</span></span>
                    <span class="pack-hours">20 Ore / mese</span>
                  </div>
                  <p class="pack-desc">Per aziende in crescita. Include troubleshooting rapido, patch management e audit periodico.</p>
                  <div class="pack-price">€900<span class="price-period">/mese</span></div>
                </div>
              </label>

              <label class="pack-card">
                <input type="radio" name="hourly-pack" value="enterprise" />
                <div class="pack-card-inner">
                  <div class="pack-header">
                    <span class="pack-name">Pack Enterprise</span>
                    <span class="pack-hours">50 Ore / mese</span>
                  </div>
                  <p class="pack-desc">Copertura estesa per infrastrutture IT complesse. Include hardening di sicurezza, backup continui e tempo di risposta prioritario.</p>
                  <div class="pack-price">€2.000<span class="price-period">/mese</span></div>
                </div>
              </label>
            </div>
          </div>

          <div class="price-summary">
            <div class="total-row">
              <span>Canone Mensile</span>
              <span class="total-amount" id="hourly-total">€500/mese</span>
            </div>
          </div>

          <button class="btn btn-primary btn-lg stripe-pay-btn" id="pay-hourly">
            <span>Attiva Abbonamento con Stripe</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </div>
      )}

      <!-- 3. HARDWARE CONFIGURATOR (Assemblaggio PC/Workstation/Server) -->
      {isHardware && (
        <div class="config-flow" data-type="hardware">
          <div class="config-group">
            <span class="group-label">Modello di Base</span>
            <div class="hardware-base-select">
              <label class="hw-base-row active">
                <input type="radio" name="hw-base" value="workstation" checked />
                <span class="hw-radio-custom"></span>
                <span class="hw-details">
                  <span class="hw-name">Workstation Dev AI (Singola GPU RTX 4090)</span>
                  <span class="hw-desc">Ideale per sviluppatori AI e fine-tuning di modelli linguistici medi. AMD Ryzen 9, 64GB DDR5, 2TB SSD NVMe.</span>
                </span>
                <span class="hw-price">€2.500</span>
              </label>

              <label class="hw-base-row">
                <input type="radio" name="hw-base" value="server-pro" />
                <span class="hw-radio-custom"></span>
                <span class="hw-details">
                  <span class="hw-name">Server AI Locale Pro (Dual GPU RTX 4090) <span class="badge badge-mini">Consigliato</span></span>
                  <span class="hw-desc">Server rack o tower ottimizzato per ospitare LLM aziendali on-premise con RAG e flussi multi-utente. AMD Threadripper, 128GB RAM.</span>
                </span>
                <span class="hw-price">€5.800</span>
              </label>

              <label class="hw-base-row">
                <input type="radio" name="hw-base" value="server-enterprise" />
                <span class="hw-radio-custom"></span>
                <span class="hw-details">
                  <span class="hw-name">Server AI Enterprise Cluster (4x RTX 4090)</span>
                  <span class="hw-desc">La potenza massima on-premise per addestramento continuo, agenti multipli e carichi intensivi aziendali. Raffreddamento a liquido personalizzato.</span>
                </span>
                <span class="hw-price">€12.500</span>
              </label>
            </div>
          </div>

          <div class="config-group">
            <span class="group-label">Opzioni Hardware & Sistemi</span>
            
            <label class="option-row">
              <input type="checkbox" id="hw-upgrade" class="config-checkbox" />
              <span class="checkbox-custom"></span>
              <span class="option-details">
                <span class="option-name">Raddoppio RAM & Storage SSD NVMe</span>
                <span class="option-desc">Espansione per gestire dataset e contesti massivi. Raddoppia la RAM del sistema e aggiunge 4TB di storage SSD NVMe PCIe 5.0 ad altissima velocità.</span>
              </span>
              <span class="option-price">+€400</span>
            </label>

            <label class="option-row">
              <input type="checkbox" id="hw-hardening" class="config-checkbox" checked />
              <span class="checkbox-custom"></span>
              <span class="option-details">
                <span class="option-name">Hardening OS & Setup AI Engine Locale (Ollama / RAG)</span>
                <span class="option-desc">Installazione OS sicuro (Linux Ubuntu Server hardened), driver NVIDIA CUDA, Ollama locale e configurazione API protetta per la rete aziendale.</span>
              </span>
              <span class="option-price">+€300</span>
            </label>
          </div>

          <div class="price-summary">
            <div class="summary-row">
              <span id="hw-base-title">Workstation Dev AI Base</span>
              <span id="hw-base-cost">€2.500</span>
            </div>
            <div class="summary-row dynamic-row" id="row-hw-upgrade" style="display: none;">
              <span>Raddoppio RAM & Storage Enterprise</span>
              <span>€400</span>
            </div>
            <div class="summary-row dynamic-row" id="row-hw-hardening">
              <span>Setup OS Hardening & AI Engine</span>
              <span>€300</span>
            </div>
            <div class="summary-divider"></div>
            <div class="total-row">
              <span>Totale Assemblaggio & Configurazione</span>
              <span class="total-amount" id="hardware-total">€2.800</span>
            </div>
          </div>

          <button class="btn btn-primary btn-lg stripe-pay-btn" id="pay-hardware">
            <span>Acquista con Stripe</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </div>
      )}

      <!-- 4. BOOKING CONFIGURATOR (Sistemi di prenotazione) -->
      {isBooking && (
        <div class="config-flow" data-type="booking">
          <div class="booking-tabs">
            <button class="booking-tab-btn active" data-tab="base">
              <span class="tab-title">Integrazione Base</span>
              <span class="tab-price">€300/mese</span>
            </button>
            <button class="booking-tab-btn" data-tab="custom">
              <span class="tab-title">Sviluppo Su Misura</span>
              <span class="tab-price">Su Preventivo</span>
            </button>
          </div>

          <div class="booking-tab-content active" id="tab-content-base">
            <div class="booking-details-box">
              <h4>Cosa include l'Integrazione Base:</h4>
              <ul class="booking-features">
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                  Setup e configurazione del sistema di booking standard
                </li>
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                  Sincronizzazione bidirezionale con Google Calendar / Outlook
                </li>
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                  Integrazione GDPR locale per il consenso del trattamento dati
                </li>
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                  Assistenza tecnica e manutenzione ordinaria mensile
                </li>
              </ul>
            </div>
            <div class="price-summary">
              <div class="total-row">
                <span>Canone Mensile</span>
                <span class="total-amount">€300/mese</span>
              </div>
            </div>
            <button class="btn btn-primary btn-lg stripe-pay-btn" id="pay-booking">
              <span>Abbonati con Stripe</span>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
          </div>

          <div class="booking-tab-content" id="tab-content-custom">
            <div class="booking-details-box">
              <h4>Per flussi complessi e logiche dedicate:</h4>
              <p class="custom-p">Hai bisogno di un sistema di prenotazione con pagamenti anticipati complessi, appuntamenti medici multi-sede, integrazione diretta nel tuo ERP personalizzato o app per pazienti/clienti?</p>
              <p class="custom-p">I nostri ingegneri progetteranno il modulo di booking su misura per le tue specifiche operative.</p>
            </div>
            <a href="/contatti" class="btn btn-ghost btn-lg booking-contact-btn">
              <span>Richiedi Consulenza Gratuita</span>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      )}

    </div>
  </div>
) : (
  <div class="container cta-detail reveal-up" id="standard-cta">
    <h2>Interessato a questo servizio?</h2>
    <p>Parla direttamente con un nostro architetto software. Senza intermediari commerciali.</p>
    <a href="/contatti" class="btn btn-primary btn-lg">Richiedi Consulenza Gratuita</a>
  </div>
)}

<!-- Stripe Processing Modal Overlay -->
<div id="stripe-modal" class="stripe-modal" hidden>
  <div class="stripe-modal-content">
    <div class="stripe-loading-screen" id="stripe-loading">
      <div class="stripe-spinner"></div>
      <h4>Elaborazione Transazione con Stripe...</h4>
      <p>Verifica della connessione protetta e inizializzazione del modulo di checkout sicuro.</p>
    </div>
    
    <div class="stripe-success-screen" id="stripe-success" style="display: none;">
      <div class="success-icon-wrapper">
        <svg class="success-checkmark" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>
      <h4>Pagamento Ricevuto!</h4>
      <p>Il pagamento è stato completato con successo. Riceverai la fattura elettronica e una mail di riepilogo da parte di Shazark Srl.</p>
      <p class="redirect-msg">I nostri tecnici ti contatteranno entro 2 ore lavorative per avviare il progetto.</p>
      <button class="btn btn-primary" id="close-stripe-success">Chiudi</button>
    </div>
  </div>
</div>
<div id="stripe-overlay" class="stripe-overlay" hidden></div>

<style>
  .configurator-wrapper {
    margin-top: 3rem;
    background: rgba(28, 28, 30, 0.6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    backdrop-filter: saturate(1.8) blur(20px);
    -webkit-backdrop-filter: saturate(1.8) blur(20px);
    overflow: hidden;
  }

  .input-field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .file-upload-wrapper {
    position: relative;
    width: 100%;
  }

  .file-upload-input {
    position: absolute;
    inset: 0;
    opacity: 0;
    width: 100%;
    height: 100%;
    cursor: pointer;
    z-index: 2;
  }

  .file-upload-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 1rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px dashed var(--color-border-hover);
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    font-size: 14px;
    transition: all var(--duration-base) ease;
  }

  .file-upload-input:hover ~ .file-upload-btn {
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--color-accent);
  }

  .file-list {
    font-size: 12px;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
    padding-left: 0.25rem;
  }

  .configurator-inner {
    padding: 2.5rem;
  }

  @media (max-width: 640px) {
    .configurator-inner {
      padding: 1.5rem;
    }
  }

  .configurator-header {
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1.5rem;
  }

  .stripe-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(99, 91, 255, 0.1);
    color: #635bff;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-pill);
    border: 1px solid rgba(99, 91, 255, 0.25);
    margin-bottom: 1.25rem;
  }

  .stripe-icon {
    flex-shrink: 0;
  }

  .secure-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .configurator-title {
    font-size: 1.8rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }

  .configurator-subtitle {
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* Form Elements & Config Groups */
  .config-group {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .group-label {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--color-text-muted);
    letter-spacing: 0.07em;
  }

  /* Option Row (Checkboxes) */
  .option-row {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.25rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--duration-base) ease;
    position: relative;
    user-select: none;
  }

  .option-row:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: var(--color-border-hover);
  }

  .option-row input[type="checkbox"] {
    position: absolute;
    opacity: 0;
    cursor: pointer;
    height: 0;
    width: 0;
  }

  .checkbox-custom {
    position: relative;
    height: 20px;
    width: 20px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--color-border-hover);
    border-radius: 5px;
    flex-shrink: 0;
    margin-top: 2px;
    transition: all var(--duration-fast) ease;
  }

  .option-row input:checked ~ .checkbox-custom {
    background: var(--color-accent);
