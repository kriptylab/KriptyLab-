---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const soluzioniEntries = await getCollection('soluzioni');
  return soluzioniEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="solution-detail">
    <header class="detail-hero">
      <div class="container">
        <div class="reveal-up">
          <span class="badge">Soluzione</span>
        </div>
        <h1 class="detail-title reveal-up delay-100">{entry.data.title}</h1>
      </div>
    </header>

    <section class="section">
      <div class="container">
        <div class="prose reveal-up delay-200">
          <Content />
        </div>
      </div>
    </section>

    <section class="section section-border">
      <div class="container cta-detail reveal-up">
        <h2>Vuoi questa soluzione?</h2>
        <p>Contattaci per un preventivo personalizzato.</p>
        <a href="/contatti" class="btn btn-primary btn-lg">Richiedi Preventivo</a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .detail-hero {
    padding: 8rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
  }
  .detail-title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    margin-top: 1.5rem;
  }
  .cta-detail {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }
  .cta-detail h2 {
    font-size: 1.8rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
  }
  .cta-detail p {
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
  }
</style>
