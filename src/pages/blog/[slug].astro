---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={`${entry.data.title} | Blog | KriptyLab`} description={entry.data.description}>
  <article class="blog-detail">
    <header class="detail-hero">
      <div class="container detail-hero-inner">
        <div class="reveal-up">
          <a href="/blog" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Torna al Blog
          </a>
        </div>

        {entry.data.keyword && (
          <span class="detail-keyword reveal-up delay-100">{entry.data.keyword}</span>
        )}

        <h1 class="detail-title reveal-up delay-200">
          {entry.data.title}
        </h1>

        <p class="detail-excerpt reveal-up delay-300">
          {entry.data.description}
        </p>

        <div class="detail-divider reveal-up delay-400"></div>
      </div>
    </header>

    <section class="section">
      <div class="container">
        <div class="prose reveal-up">
          <Content />
        </div>
      </div>
    </section>

    <section class="section section-border">
      <div class="container cta-detail reveal-up">
        <h2>Ti è stato utile questo articolo?</h2>
        <p>Se vuoi approfondire o hai un progetto in mente, parla con noi.</p>
        <a href="/contatti" class="btn btn-primary btn-lg">Contattaci</a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .detail-hero {
    padding: 8rem 0 0;
  }

  .detail-hero-inner {
    max-width: 720px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
    transition: color var(--duration-fast) ease;
  }
  .back-link:hover { color: var(--color-accent); }

  .detail-keyword {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .detail-title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .detail-excerpt {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    text-wrap: balance;
    margin-bottom: 2rem;
  }

  .detail-divider {
    height: 1px;
    background: var(--color-border);
    width: 100%;
  }

  .prose {
    max-width: 720px;
  }

  .cta-detail {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }

  .cta-detail h2 {
    font-size: 1.8rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
  }

  .cta-detail p {
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
  }
</style>
