---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contatti | KriptyLab" description="Parla con i nostri architetti software per il tuo prossimo progetto IT.">
  <section class="hero-page">
    <div class="container">
      <div class="reveal-up">
        <span class="badge">Contattaci</span>
      </div>
      <h1 class="page-title reveal-up delay-100">Contattaci</h1>
      <p class="page-subtitle reveal-up delay-200">
        Raccontaci la tua infrastruttura o la tua idea. Riceverai una consulenza tecnica da chi scriverà effettivamente il codice.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="form-wrapper card reveal-up delay-300">
        <div class="form-inner">
          <form class="contact-form" action="#" method="POST">
            <div class="form-row">
              <div class="form-field">
                <label for="name" class="form-label">Nome e Cognome</label>
                <input type="text" id="name" name="name" class="form-input" placeholder="Mario Rossi" required>
              </div>
              <div class="form-field">
                <label for="azienda" class="form-label">Azienda</label>
                <input type="text" id="azienda" name="azienda" class="form-input" placeholder="La tua azienda Srl" required>
              </div>
            </div>

            <div class="form-field">
              <label for="email" class="form-label">Email Lavorativa</label>
              <input type="email" id="email" name="email" class="form-input" placeholder="mario@azienda.it" required>
            </div>

            <div class="form-field">
              <label for="messaggio" class="form-label">Di cosa hai bisogno?</label>
              <textarea id="messaggio" name="messaggio" class="form-input" rows="5" placeholder="Descrivi brevemente il tuo progetto o la tua esigenza..." required></textarea>
            </div>

            <div class="form-submit">
              <button type="submit" class="btn btn-primary btn-lg form-submit-btn">
                Invia Richiesta
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </button>
              <p class="form-note">
                Sostituisci questo blocco HTML con l'embed form fornito da Brevo.
              </p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-page {
    padding: 8rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
    position: relative;
  }
  .hero-page::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(0, 122, 255, 0.05) 0%, transparent 70%);
    pointer-events: none;
  }
  .page-title {
    font-size: clamp(2.5rem, 5vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    margin-top: 1.5rem;
    margin-bottom: 1rem;
  }
  .page-subtitle {
    font-size: 1.15rem;
    color: var(--color-text-secondary);
    max-width: 560px;
    text-wrap: balance;
    line-height: 1.7;
  }

  .form-wrapper {
    max-width: 680px;
  }

  .form-inner {
    padding: 2.5rem;
  }

  @media (min-width: 768px) {
    .form-inner { padding: 3rem; }
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .form-row { grid-template-columns: 1fr 1fr; }
  }

  .form-submit {
    padding-top: 0.5rem;
  }

  .form-submit-btn {
    width: 100%;
  }

  .form-note {
    font-size: 12px;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: 1rem;
  }
</style>
