---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const raw = (await getCollection('servizi')).filter(s => s.id !== 'index');
const allServices = [
  ...raw.filter(s => s.id === 'sviluppo-siti-web'),
  ...raw.filter(s => s.id !== 'sviluppo-siti-web'),
];
---
<BaseLayout title="Servizi IT & Software | KriptyLab" description="Esplora le nostre competenze in sviluppo software, AI e Cybersecurity.">
  <section class="hero-page">
    <div class="container">
      <div class="hero-content reveal-up">
        <span class="badge">I Nostri Servizi</span>
        <h1 class="page-title">Architetture <span class="text-gradient">Digitali.</span></h1>
        <p class="page-subtitle">Dal codice server-side alla sicurezza di rete, copriamo l'intero ecosistema tecnologico.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="services-listing">
        {allServices.map((servizio, index) => (
          <a href={`/servizi/${servizio.id}`} class={`card service-list-card reveal-up`} style={`transition-delay: ${(index % 6) * 60}ms`}>
            <div class="service-list-inner">
              <div class="service-list-content">
                <h3>{servizio.data.title}</h3>
                <p>{servizio.data.description}</p>
              </div>
              <span class="arrow-link">
                Esplora
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-page {
    padding: 8rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
    position: relative;
  }
  .hero-page::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(0, 122, 255, 0.05) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-content { position: relative; }
  .page-title {
    font-size: clamp(2.5rem, 5vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    margin-top: 1.5rem;
    margin-bottom: 1rem;
  }
  .page-subtitle {
    font-size: 1.15rem;
    color: var(--color-text-secondary);
    max-width: 560px;
    text-wrap: balance;
  }

  .services-listing {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .services-listing { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .services-listing { grid-template-columns: repeat(3, 1fr); }
  }

  .service-list-card {
    text-decoration: none;
  }

  .service-list-inner {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .service-list-content {
    flex-grow: 1;
  }

  .service-list-card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
    letter-spacing: -0.02em;
  }

  .service-list-card p {
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .service-list-card .arrow-link {
    margin-top: auto;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
    font-size: 14px;
  }
</style>
