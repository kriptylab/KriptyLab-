---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const serviziEntries = await getCollection('servizi');
  return serviziEntries.filter(entry => entry.id !== 'index').map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="service-detail">
    <header class="detail-hero">
      <div class="container">
        <div class="reveal-up">
          <a href="/servizi" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Torna ai Servizi
          </a>
        </div>
        {entry.data.keyword && (
          <span class="detail-keyword reveal-up delay-100">{entry.data.keyword}</span>
        )}
        <h1 class="detail-title reveal-up delay-200">{entry.data.title}</h1>
      </div>
    </header>

    <section class="section">
      <div class="container">
        <div class="prose reveal-up delay-300">
          <Content />
        </div>
      </div>
    </section>

    <section class="section section-border">
      <div class="container cta-detail reveal-up">
        <h2>Interessato a questo servizio?</h2>
        <p>Parla direttamente con un nostro architetto software.</p>
        <a href="/contatti" class="btn btn-primary btn-lg">Richiedi Consulenza</a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .detail-hero {
    padding: 8rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
    transition: color var(--duration-fast) ease;
  }
  .back-link:hover { color: var(--color-accent); }
  .detail-keyword {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: 0.75rem;
  }
  .detail-title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
  }
  .cta-detail {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }
  .cta-detail h2 {
    font-size: 1.8rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
  }
  .cta-detail p {
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
  }
</style>
