---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    label: 'NDA Protected',
    tags: [{ text: 'AI On-Premise', accent: true }, { text: 'Sanità Privata', accent: false }],
    title: 'Polo Medico Privato',
    desc: "Implementazione di un server LLM locale per l'analisi di referti medici senza invio di dati al cloud. Conformità GDPR e privacy totale by-design.",
    image: '/img-medical-ai.svg'
  },
  {
    label: 'Live System',
    tags: [{ text: 'Gestionale Web', accent: true }, { text: 'Logistica', accent: false }],
    title: 'Automazione Magazzino',
    desc: "Sviluppo di un gestionale headless in React e Go per il tracciamento in tempo reale di flotte e stock di magazzino. Miglioramento latenza API del 300%.",
    image: '/img-warehouse.svg'
  }
];
---
<BaseLayout title="Casi Studio & Progetti | KriptyLab" description="Scopri come abbiamo trasformato le PMI italiane con codice e server.">
  <section class="hero-page">
    <div class="container">
      <div class="reveal-up">
        <span class="badge">Portfolio</span>
      </div>
      <h1 class="page-title reveal-up delay-100">Casi <span class="text-gradient">Studio.</span></h1>
      <p class="page-subtitle reveal-up delay-200">Hardware on-premise, software scalabile, risultati misurabili.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="projects-grid">
        {projects.map((project, index) => (
          <div class={`card project-card reveal-up`} style={`transition-delay: ${(index + 1) * 100}ms`}>
            <div class="project-preview">
              {project.image
                ? <img src={project.image} alt={project.title} class="project-img" />
                : <div class="project-pattern"></div>
              }
              <span class="project-label">{project.label}</span>
            </div>
            <div class="project-body">
              <div class="project-tags">
                {project.tags.map(tag => (
                  <span class={tag.accent ? 'tag' : 'tag tag-neutral'}>{tag.text}</span>
                ))}
              </div>
              <h3>{project.title}</h3>
              <p>{project.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-page {
    padding: 8rem 0 3rem;
    border-bottom: 1px solid var(--color-border);
    position: relative;
  }
  .hero-page::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(0, 122, 255, 0.05) 0%, transparent 70%);
    pointer-events: none;
  }
  .page-title {
    font-size: clamp(2.5rem, 5vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    margin-top: 1.5rem;
    margin-bottom: 1rem;
  }
  .page-subtitle {
    font-size: 1.15rem;
    color: var(--color-text-secondary);
    max-width: 560px;
    text-wrap: balance;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .projects-grid { grid-template-columns: 1fr 1fr; }
  }

  .project-card {
    overflow: hidden;
    cursor: default;
  }

  .project-preview {
    aspect-ratio: 16 / 9;
    background: var(--color-surface-hover);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .project-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.4;
    background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.05) 1px, transparent 0);
    background-size: 20px 20px;
  }

  .project-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .project-label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    position: relative;
    z-index: 1;
  }

  .project-body {
    padding: 2rem;
  }

  .project-tags {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .project-card h3 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .project-card p {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }
</style>
